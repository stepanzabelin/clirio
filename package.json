{
  "name": "clirio",
  "version": "4.0.0",
  "description": "Clirio is a mini framework for node.js command-line interfaces",
  "main": "build/main/index.js",
  "types": "build/main/index.d.ts",
  "typings": "build/main/index.d.ts",
  "module": "build/module/index.js",
  "repository": "https://github.com/stepanzabelin/clirio",
  "license": "MIT",
  "packageManager": "yarn@4.17.0",
  "keywords": [
    "cli",
    "console",
    "command",
    "option",
    "parser",
    "argument",
    "args",
    "argv",
    "terminal",
    "shell",
    "interface"
  ],
  "author": "Stepan Zabelin",
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); if (fs.existsSync('build')) (fs.rmSync ? fs.rmSync('build', { recursive: true, force: true }) : fs.rmdirSync('build', { recursive: true }))\"",
    "build": "run-s clean build:compile",
    "build:compile": "run-p build:main build:module",
    "build:main": "tsc -p tsconfig.main.json",
    "build:module": "tsc -p tsconfig.module.json",
    "watch:build": "tsc -p tsconfig.json -w",
    "fix:prettier": "prettier --write \"./{src,tests,test-cli-app}/**/*.ts\"",
    "fix:eslint": "eslint \"./src/**/*.ts\" \"./tests/**/*.ts\"  \"./test-cli-app/**/*.ts\" --fix",
    "fix": "run-s \"fix:*\"",
    "test:eslint": "eslint \"./src/**/*.ts\" \"./tests/**/*.ts\"  \"./test-cli-app/**/*.ts\" --quiet",
    "test:typescript": "tsc -p tsconfig.json --noEmit",
    "test:cspell": "cspell \"./{src,test-cli-app}/**/*.ts\" --no-progress",
    "test:unit": "jest --silent=false --bail",
    "test:package": "node scripts/check-package-entry.cjs",
    "test": "run-s build \"test:*\"",
    "prepack": "run-s build",
    "prepare": "husky",
    "dev": "ts-node -r tsconfig-paths/register test-cli-app/run"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/sinon": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "cspell": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.9.4",
    "sinon": "^22.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "resolutions": {
    "glob@npm:^10.4.1": "npm:13.0.6",
    "glob@npm:^10.5.0": "npm:13.0.6",
    "test-exclude@npm:^6.0.0": "npm:7.0.1"
  },
  "files": [
    "build/main/**/*",
    "build/module/**/*",
    "!**/*.spec.*",
    "!**/*.json",
    "scripts/check-package-entry.cjs",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ]
}

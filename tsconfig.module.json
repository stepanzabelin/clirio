{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "target": "ES2021",
    "outDir": "build/module",
    "module": "ESNext",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "build/**",
    "node_modules/**"
  ]
}

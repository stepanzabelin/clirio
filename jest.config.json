{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "\\.spec\\.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "/build/"
  ],
  "moduleNameMapper": {
    "^@clirio$": "<rootDir>/src/index.ts"
  },
  "maxWorkers": 1
}
